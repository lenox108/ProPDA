# Подпись сборки ru.forpdateam.forpda.parallel (рядом с оригиналом из Play).
# 1) Создайте keystore: ./scripts/create-parallel-keystore.sh
# 2) Скопируйте этот файл: cp keystore.parallel.properties.example keystore.parallel.properties
# 3) Заполните пароли и при необходимости путь к .jks

STORE_FILE=signing/forpda-parallel.jks
STORE_PASSWORD=your_store_password
KEY_ALIAS=forpda_parallel
KEY_PASSWORD=your_key_password
