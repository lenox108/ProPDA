<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:targetApi="34" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />
    <!--
      Нужно для прямого системного диалога «не оптимизировать батарею»
      (ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS). Без исключения из Doze система
      откладывает периодическую фоновую проверку на часы, пока приложение закрыто.
      Клиент распространяется сайдлоадом (не через Play), политика Play здесь неприменима.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!--
      Точный будильник — «пробивной» триггер фоновой проверки уведомлений (Doze откладывает
      WorkManager на часы). API 31-32 — SCHEDULE_EXACT_ALARM (отзываемое), API 33+ —
      USE_EXACT_ALARM (выдаётся всегда; сайдлоад, политика Play неприменима).
    -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Перевзвод будильника фоновой проверки после перезагрузки/обновления (иначе alarm-цепь
         молчит до первого срабатывания страховочного периодика — до получаса). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Постоянное соединение (опция): FGS без 6-часового лимита dataSync (Android 15). -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"
        tools:targetApi="34" />

    <queries>
        <package android:name="com.android.chrome" />
        <package android:name="org.mozilla.firefox" />
        <package android:name="com.microsoft.emmx" />
        <package android:name="com.sec.android.app.sbrowser" />
        <package android:name="com.opera.browser" />
        <package android:name="com.opera.mini.native" />
        <package android:name="com.yandex.browser" />

        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:fullBackupContent="false"
        android:extractNativeLibs="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:logo="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/DayNightAppTheme"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".ui.activities.BannedActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/DayNightAppTheme.NoActionBar" />
        <activity
            android:name=".ui.activities.MainActivity"
            android:configChanges="keyboardHidden|screenSize|orientation"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.ForPDA.Splash"
            android:windowSoftInputMode="adjustResize">
            <!--
                Фильтра MAIN/LAUNCHER здесь НЕТ: ярлык даёт включённый activity-alias
                (см. ниже, «Иконки запуска»). Иначе к выбранной иконке добавлялся бы
                второй ярлык — от самой MainActivity.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="4pda.to"
                    android:scheme="http" />
                <data
                    android:host="www.4pda.to"
                    android:scheme="http" />
                <data
                    android:host="4pda.to"
                    android:scheme="https" />
                <data
                    android:host="www.4pda.to"
                    android:scheme="https" />

            </intent-filter>

            <meta-data
                android:name="android.max_aspect"
                android:value="2.1" />
        </activity>

        <!--
            Иконки запуска. Один activity-alias на вариант: включён ровно один,
            переключением занимается AppIconManager. Требования к правкам:
              * android:name и порядок трогать нельзя — на имена ссылаются ярлыки
                на рабочем столе, а id варианта хранится в настройках;
              * shortcuts объявляем на каждом псевдониме: система читает
                android.app.shortcuts только у компонента с MAIN/LAUNCHER;
              * новые варианты добавляет design/app-icon/add_alt_icon.py.
        -->
        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>


        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.FourDark"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_four_dark"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_four_dark"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.FourBlue"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_four_blue"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_four_blue"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.Puzzle"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_puzzle"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_puzzle"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.FourOrange"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_four_orange"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_four_orange"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.Glass4"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_glass_4"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_glass_4"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.Metal4"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_metal_4"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_metal_4"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.Holo4"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_holo_4"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_holo_4"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name="forpdateam.ru.forpda.Launcher.Matrix4"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_matrix_4"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_matrix_4"
            android:targetActivity=".ui.activities.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <!-- app-icon-variants:aliases — не удалять, сюда дописывает add_alt_icon.py -->

        <activity
            android:name=".ui.activities.imageviewer.ImageViewerActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/DayNightAppTheme.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.activities.SettingsActivity"
            android:exported="false"
            android:label="@string/activity_title_settings"
            android:theme="@style/DayNightPreferenceTheme"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="android.max_aspect"
                android:value="2.1" />
        </activity>

        <activity
            android:name=".ui.activities.WebVewNotFoundActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/DayNightAppTheme.NoActionBar" />

        <service
            android:name=".notifications.NotificationsService"
            android:exported="false"
            android:foregroundServiceType="dataSync|specialUse">
            <!-- Android 14+: обязательное декларирование назначения specialUse-FGS. -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent WebSocket connection for forum push notifications (user opt-in); FCM unavailable for this sideloaded client" />
        </service>

        <!-- Точный будильник фоновой проверки уведомлений (второй контур к WorkManager). -->
        <receiver
            android:name=".notifications.EventsCheckAlarmReceiver"
            android:exported="false" />

        <!-- Перевзвод будильника после перезагрузки устройства и обновления приложения. -->
        <receiver
            android:name=".notifications.EventsCheckBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- WorkManager foreground downloads require explicit type on Android 14+ -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Действия из шторки уведомлений: «Ответить» (QMS) / «Прочитано». -->
        <receiver
            android:name=".notifications.NotificationActionReceiver"
            android:exported="false" />
    </application>

</manifest>
