<?xml version="1.0" encoding="UTF-8"?>
<!-- Обводка через layer-list: stroke у shape обрезается по краям TextView и выглядит «срезанной». -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/light_card_background" />
            <corners android:radius="11dp" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#ef5350" />
            <corners android:radius="9dp" />
        </shape>
    </item>
</layer-list>
