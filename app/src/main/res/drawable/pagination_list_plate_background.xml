<?xml version="1.0" encoding="utf-8"?>
<!-- Обводка как у остальных list-plate; верхняя панель использует отдельный drawable без stroke. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/content_card_surface" />
            <stroke
                android:width="?attr/list_plate_stroke_width"
                android:color="?attr/list_plate_stroke_color" />
            <corners android:radius="@dimen/card_corner_radius" />
        </shape>
    </item>
</layer-list>
