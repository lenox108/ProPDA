<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24.0"
    android:viewportHeight="24.0">
    <!-- Rounded speech bubble — exact match of the WebView post-action-reply-icon (stroke, round).
         The raw bubble path fills only ~62% of the 24-box (vs ~71% for the quote «⇄» icon), so it read
         visibly smaller in the action row. Scale it 1.13× about its centre to match the neighbouring
         icons; strokeWidth is pre-divided by the same factor so the RENDERED stroke stays 1.5. -->
    <group
        android:scaleX="1.13"
        android:scaleY="1.13"
        android:pivotX="12"
        android:pivotY="12.25">
        <path
            android:fillColor="@android:color/transparent"
            android:strokeColor="?attr/colorOnSurfaceVariant"
            android:strokeWidth="1.33"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M12,4.5 a7.5,7.5 0 0 1 7.5,7.5 a7.5,7.5 0 0 1 -7.5,7.5 a7.3,7.3 0 0 1 -3.1,-0.68 L5,20 l1.18,-3.75 A7.46,7.46 0 0 1 4.5,12 A7.5,7.5 0 0 1 12,4.5 z" />
    </group>
</vector>
