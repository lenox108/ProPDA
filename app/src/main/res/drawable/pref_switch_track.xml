<?xml version="1.0" encoding="utf-8"?>
<!--
    Compact, OPAQUE track for the settings SwitchCompat. The legacy appcompat
    track (abc_switch_track_mtrl_alpha) is semi-transparent, so a tint rendered
    faint; this solid pill keeps the vivid colour of an M3 switch but at the
    smaller SwitchCompat size the user prefers. Colour is set via trackTint in
    SwitchPreference.onBind. Fill is white so the tint reproduces exactly.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFFFFFF" />
    <corners android:radius="100dp" />
    <size android:width="36dp" android:height="20dp" />
</shape>
