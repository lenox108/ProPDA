<?xml version="1.0" encoding="utf-8"?>
<!--
  Middle row of an «other menu» plate: the group must read as ONE card, so the row draws the plate's
  side strokes but NEITHER the top nor the bottom edge — otherwise every seam between rows showed a
  full-bleed hairline. Separation inside the plate is an M3 inset divider drawn by the row itself.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/content_card_surface" />
            <stroke
                android:width="?attr/list_plate_stroke_width"
                android:color="?attr/list_plate_stroke_color" />
            <corners android:radius="0dp" />
        </shape>
    </item>
    <item
        android:height="?attr/list_plate_stroke_width"
        android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="?attr/content_card_surface" />
        </shape>
    </item>
    <item
        android:height="?attr/list_plate_stroke_width"
        android:gravity="bottom">
        <shape android:shape="rectangle">
            <solid android:color="?attr/content_card_surface" />
        </shape>
    </item>
</layer-list>
