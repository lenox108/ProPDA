    <!--
        Material You SURFACE overlay: night-mode override.
        Зеркало values/styles.xml (см. полный KDoc там). Динамический базовый
        фон (colorSurface/colorOnSurface) + anti-crash статика для link_color и
        типографики (ночные @color/dark_*). Остальной хром/фоны/иконки НЕ
        переопределяются — наследуются из базовой DayNightAppTheme (night) с теми
        же @color/dark_* значениями; их дубликаты-no-op убраны как мёртвый код.
        Динамический трекинг палитры обоев для поверхностей тут невозможен
        (custom-attr через TypedArray.getColorStateList не дерефят TYPE_ATTRIBUTE,
        см. 775b344 / b8b7b57 / 65c64b8 / e725c7f).
    -->
    <style name="ThemeOverlay.ForPDA.MaterialYouSurface" parent="ThemeOverlay.ForPDA.MaterialYouAccent">
        <!--
            Динамический базовый фон. Framework-M3-роли (colorSurface /
            colorOnSurface) — AOSP-инфлейтер резолвит их напрямую.
        -->
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="colorOnBackground">?attr/colorOnSurface</item>

        <!--
            Верхняя плашка тулбара = фон контента (?attr/colorSurfaceContainerLowest),
            чтобы «плоский» top-bar chrome главных разделов сливался с фоном (см.
            KDoc в values/styles.xml). Без этого в тёмной теме плашка оставалась
            статичным dark_main_toolbar_accent_surface (#242424) — отдельной серой
            полосой над фоном.
        -->
        <item name="main_toolbar_accent_surface">?attr/colorSurfaceContainerLowest</item>

        <!--
            Маркер динамического полотна хрома (ChromeCanvas.kt) — ОБЯЗАН
            дублироваться в обеих конфигурациях стиля (values/ и values-night/):
            ночной ресурс полностью ЗАМЕЩАЕТ дневной, а не мержится с ним.
            Без дубля тёмная тема шла по static-пути и полотно не тонировалось
            обоями (см. KDoc дневной версии).
        -->
        <item name="chrome_canvas_dynamic">true</item>

        <!--
            Anti-crash: КОНКРЕТНЫЕ @color/dark_* (см. KDoc в values/styles.xml).
            link_color — обязательное переопределение родителя MaterialYouAccent
            (?attr/colorPrimary → static), иначе TextView.<init> падает.
        -->
        <item name="android:textColor">@color/dark_default_text_color</item>
        <item name="android:textColorPrimary">@color/dark_default_text_color</item>
        <item name="android:textColorSecondary">@color/dark_second_text_color</item>
        <item name="android:textColorLink">@color/dark_link_color</item>
        <item name="android:textColorHint">@color/dark_second_text_color</item>
    </style>

