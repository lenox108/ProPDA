<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="SplashTheme" parent="DayNightAppTheme.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_splash_dark</item>
    </style>

    <!-- Night-вариант SplashScreen-темы (см. values/styles.xml Theme.ForPDA.Splash). -->
    <style name="Theme.ForPDA.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_colorPrimary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/DayNightAppTheme.NoActionBar</item>
    </style>

    <!--
        DARK THEME - Original dark gray theme
    -->
    <style name="DayNightAppTheme" parent="Theme.Material3.DayNight">
        <!-- Base color settings -->
        <item name="colorPrimary">@color/dark_colorPrimary</item>
        <item name="colorPrimaryDark">@color/dark_colorPrimaryDark</item>
        <item name="colorAccent">@color/dark_colorAccent</item>
        <item name="colorSecondary">@color/dark_link_color</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.ForPDA.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.ForPDA.Medium</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSurface">@color/dark_card_background</item>
        <item name="colorOnSurface">@color/dark_default_text_color</item>
        <!-- Explicit Material 3 tonal colors to prevent broken auto-computation -->
        <item name="colorOnPrimary">@color/dark_default_text_color</item>
        <item name="colorPrimaryContainer">@color/dark_card_background</item>
        <item name="colorOnPrimaryContainer">@color/dark_default_text_color</item>
        <item name="colorSecondaryContainer">@color/dark_card_background</item>
        <item name="colorOnSecondaryContainer">@color/dark_default_text_color</item>
        <item name="colorSurfaceVariant">@color/dark_card_background</item>
        <item name="colorOnSurfaceVariant">@color/dark_second_text_color</item>
        <item name="colorControlHighlight">#33FFFFFF</item>
        <item name="android:colorControlHighlight">#33FFFFFF</item>
        <!-- Toolbar icon colors -->
        <item name="colorControlNormal">?icon_toolbar</item>
        <item name="android:colorControlNormal">?icon_toolbar</item>
        <!-- Switch/CheckBox active color — same as buttons -->
        <item name="colorControlActivated">?attr/colorAccent</item>
        <item name="android:colorControlActivated">?attr/colorAccent</item>
        <item name="android:textCursorDrawable">@drawable/text_cursor</item>
        <item name="android:textSelectHandle">@drawable/text_select_handle</item>
        <item name="android:textSelectHandleLeft">@drawable/text_select_handle_left</item>
        <item name="android:textSelectHandleRight">@drawable/text_select_handle_right</item>
        <item name="android:textSelectHandleWindowStyle">@style/Widget.ForPDA.TextSelectHandleWindow</item>
        <item name="actionBarTheme">@style/DayNightAppTheme.AppBarOverlay</item>
        <item name="toolbarStyle">@style/ToolbarStyle.Dark</item>

        <!-- Colors attr settings -->
        <item name="status_bar_color">@color/dark_status_bar_color</item>
        <item name="link_color_contrast">@color/dark_link_color_contrast</item>
        <item name="contrast_text_color">@color/dark_contrast_text_color</item>
        <item name="colorSurfaceContainerLowest">@color/dark_background_base</item>
        <item name="colorSurfaceContainerLow">@color/dark_background_base</item>
        <item name="colorSurfaceContainer">@color/dark_background_base</item>
        <item name="colorSurfaceContainerHigh">@color/dark_card_background</item>
        <item name="colorSurfaceContainerHighest">@color/dark_card_background</item>
        <item name="background_for_lists">@color/dark_background_for_lists</item>
        <item name="attachment_overlay_bg">@color/dark_attachment_overlay_bg</item>
        <item name="attachment_description_bg">@color/dark_attachment_description_bg</item>
        <item name="attachment_text">@color/dark_attachment_text</item>
        <item name="msg_panel_tooltip_bg">@color/dark_msg_panel_tooltip_bg</item>
        <item name="profile_overlay_bg">@color/dark_profile_overlay_bg</item>
        <item name="img_viewer_toolbar">@color/dark_img_viewer_toolbar</item>
        <item name="icon_base">@color/dark_icon_base</item>
        <item name="menu_tile_icon">?attr/icon_base</item>
        <item name="icon_base_inverse">@color/dark_icon_base_inverse</item>
        <item name="icon_toolbar">@color/dark_icon_toolbar</item>
        <item name="icon_toolbar_inverse">@color/dark_icon_toolbar_inverse</item>
        <item name="count_background">@drawable/count_background_dark</item>
        <item name="chrome_plane_background">@color/dark_card_background</item>
        <item name="main_toolbar_accent_surface">@color/dark_main_toolbar_accent_surface</item>
        <item name="main_toolbar_stroke_width">1dp</item>
        <item name="main_toolbar_stroke_color">@color/dark_main_toolbar_stroke</item>
        <item name="list_plate_stroke_width">0dp</item>
        <item name="list_plate_stroke_color">@android:color/transparent</item>
        <!--
            Тёмная тема: карточка = поднятый ...ContainerHigh (#242424), а не colorSurface.
            На Material You colorSurface — это тон 6 (почти чёрный, сливается со страницей-тоном 4),
            а ...ContainerHigh — тон 17, который читается как настоящий серый.
        -->
        <item name="content_card_surface">?attr/colorSurfaceContainerHigh</item>
        <item name="bottom_nav_bar_shape_appearance">@style/ShapeAppearance.ForPDA.BottomNavBar</item>
        <item name="smart_nav_fab_background">?attr/colorAccent</item>
        <item name="smart_nav_fab_icon">?attr/contrast_text_color</item>
        <item name="divider_line_bottom_nav">@color/dark_divider_line_bottom_nav</item>
        <item name="notify_dot_tab">@drawable/notify_dot_tab_dark</item>
        <item name="is_use_light_status_bar">false</item>
        <item name="item_tab_close_color">@color/dark_item_tab_close</item>


        <!-- Styles settings-->
        <item name="app_bar_overlay">@style/DayNightAppTheme.AppBarOverlay</item>
        <item name="popup_overlay">@style/DayNightAppTheme.PopupOverlay</item>
        <item name="bottom_sheet_dialog_theme">@style/DayNightAppTheme.BottomSheetDialog</item>
        <item name="tabStyle">@style/Widget.ForPDA.TabLayout</item>
        <item name="popupMenuStyle">@style/Widget.ForPDA.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.ForPDA.PopupMenu</item>
        <item name="android:popupBackground">@drawable/bg_popup_menu_m3</item>
        <item name="popupWindowStyle">@style/Widget.ForPDA.PopupWindow</item>
        <item name="android:popupWindowStyle">@style/Widget.ForPDA.PopupWindow</item>
        <item name="listPopupWindowStyle">@style/Widget.ForPDA.ListPopupWindow</item>
        <item name="android:listPopupWindowStyle">@style/Widget.ForPDA.ListPopupWindow</item>
        <item name="dropDownListViewStyle">@style/Widget.ForPDA.DropDownListView</item>
        <item name="android:dropDownListViewStyle">@style/Widget.ForPDA.DropDownListView</item>
        <item name="actionOverflowMenuStyle">@style/Widget.ForPDA.PopupMenu.Overflow</item>
        <item name="panelMenuListTheme">@style/DayNightAppTheme.PopupOverlay</item>

        <!-- Other settings -->
        <item name="ProfileToolbarTextStyle">@style/ProfileToolbarTextStyle</item>
        <item name="android:textViewStyle">@style/MyTextViewStyle</item>
        <item name="radioButtonStyle">@style/Widget.ForPDA.RadioButton</item>
        <item name="windowActionModeOverlay">true</item>
        <!--<item name="actionModeStyle">@style/ActionModeStyle</item>-->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.ForPDA</item>

        <item name="actionModeBackground">@color/dark_colorPrimary</item>
        <item name="actionModeCloseButtonStyle">@style/actionModeCloseButtonStyle</item>
        <item name="actionOverflowButtonStyle">@style/OverFlow</item>
        <item name="alertDialogTheme">@style/DayNightAppTheme.Dialog</item>
        <item name="materialAlertDialogTheme">@style/DayNightAppTheme.Dialog</item>
        <item name="bottomSheetDialogTheme">@style/DayNightAppTheme.BottomSheetDialog</item>
        <item name="android:windowBackground">@color/dark_background_base</item>
        <item name="android:navigationBarColor">@color/dark_navigation_bar_color</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <!-- colorPrimary у тёмной темы #212121 — текст кнопок AlertDialog сливался с фоном карточки -->
    <style name="DayNightAppTheme.Dialog" parent="Base.ForPDA.Dialog">
        <item name="android:colorBackground">@color/dark_card_background</item>
        <item name="colorAccent">@color/dark_link_color</item>
        <item name="colorPrimary">@color/dark_link_color</item>
        <item name="colorOnSurface">@color/dark_default_text_color</item>
