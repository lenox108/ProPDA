        <item name="popup_overlay">@style/AmoledAppTheme.PopupOverlay</item>
    </style>

    <style name="DayNightAppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:singleLine">true</item>
        <!-- Плашка вкладок = ?attr/colorSurface -->
        <item name="colorSurface">?attr/colorSurface</item>
        <item name="colorControlNormal">?icon_toolbar</item>
        <item name="colorOnSurface">?icon_toolbar</item>
        <item name="actionMenuTextColor">?icon_toolbar</item>
        <!--
            НЕ переопределяем android:textColorPrimary/Secondary здесь:
            ?icon_toolbar — ?attr/... ссылка, а при включённом Material You
            ThemeOverlay.ForPDA.MaterialYouSurface переопределяет icon_toolbar на
            ?attr/colorOnSurface — получается двух- и трёхуровневая цепочка
            ?attr/... ссылок, которую MaterialComponents.TextAppearance не может
            разрешить (UnsupportedOperationException при инфлейте CollapsingToolbarLayout).
            textColorPrimary/Secondary наследуются из
            ThemeOverlay.Material3.Dark.ActionBar -> ThemeOverlay.AppCompat.Dark.ActionBar
            и корректно перекрываются MaterialYouSurface (?attr/colorOnSurface),
            когда Material You включён.
        -->
        <item name="colorPrimary">@color/dark_link_color</item>
        <item name="colorPrimaryContainer">@color/dark_card_background</item>
        <item name="colorOnPrimaryContainer">@color/dark_default_text_color</item>
        <item name="toolbarStyle">@style/ToolbarStyle.Dark</item>
        <item name="popup_overlay">@style/DayNightAppTheme.PopupOverlay</item>
    </style>

    <style name="DayNightAppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Dark">
        <item name="elevation">0dp</item>
        <!--
            Concrete colorSurface (was a self-referential ?attr/colorSurface no-op that
            resolved to transparent). The overflow popup background @drawable/bg_popup_menu_m3
            reads ?attr/colorSurface; a self-reference collapsed it to 0 → transparent popup.
        -->
        <item name="colorSurface">@color/dark_card_background</item>
        <item name="colorOnSurface">@color/dark_default_text_color</item>
        <item name="colorOnSurfaceVariant">@color/dark_second_text_color</item>
