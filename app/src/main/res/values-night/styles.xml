        <item name="colorPrimaryContainer">@color/dark_card_background</item>
        <item name="colorOnPrimaryContainer">@color/dark_default_text_color</item>
        <item name="colorOutline">@color/dark_divider_line</item>
        <item name="android:textColorPrimary">@color/dark_default_text_color</item>
        <item name="android:textColorSecondary">@color/dark_second_text_color</item>
        <item name="android:textColorHint">@color/dialog_textinput_hint</item>
        <item name="colorSurface">@color/dark_card_background</item>
        <item name="colorOnSurfaceVariant">@color/dark_second_text_color</item>
        <item name="colorOutlineVariant">@color/dark_divider_line</item>
        <item name="buttonBarButtonStyle">@style/Widget.ForPDA.DialogButton</item>
        <item name="textInputStyle">@style/DialogTextInputStyle</item>
    </style>

    <style name="DialogTextInputStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="colorPrimary">@color/dark_link_color</item>
        <item name="colorControlActivated">@color/dark_link_color</item>
        <item name="colorControlNormal">@color/dark_second_text_color</item>
        <item name="boxStrokeColor">@color/dark_second_text_color</item>
        <item name="hintTextColor">@color/dialog_textinput_hint</item>
    </style>

    <style name="DayNightAppTheme.BottomSheetDialog" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:colorBackground">@color/dark_colorPrimary</item>
        <item name="colorSurface">@color/dark_colorPrimary</item>
        <item name="colorOnSurface">@color/dark_default_text_color</item>
        <item name="colorOnSurfaceVariant">@color/dark_second_text_color</item>
        <item name="textInputStyle">@style/DialogTextInputStyle</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.ForPDA.BottomSheet</item>
    </style>


    <style name="DayNightAppTheme.NoActionBarBase" parent="DayNightAppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/dark_navigation_bar_color</item>
    </style>

    <style name="DayNightAppTheme.NoActionBar" parent="DayNightAppTheme.NoActionBarBase" />

    <!--
        AMOLED THEME - Pure black for OLED screens
    -->
