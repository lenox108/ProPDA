    <style name="AmoledAppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="colorSurface">?attr/colorSurface</item>
        <item name="colorControlNormal">?icon_toolbar</item>
        <item name="colorOnSurface">?icon_toolbar</item>
