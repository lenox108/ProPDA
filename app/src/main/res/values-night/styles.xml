        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSurface">@color/amoled_card_background</item>
        <item name="colorOnSurface">@color/dark_default_text_color</item>
        <!-- Explicit Material 3 tonal colors to prevent broken auto-computation -->
