<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Toolbar title color, выбирается автоматически по day/night.
        В values/colors.xml = @color/light_default_text_color (#000000),
        здесь перекрывается на @color/dark_default_text_color (#ffffff).
        Используется как concrete-@color в fragment_base.xml (Fix A):
        XML-атрибут app:titleTextColor должен быть КОНКРЕТНЫМ, чтобы
        TypedArray.getColorStateList не получал TYPE_ATTRIBUTE — иначе
        Toolbar.<init> падает с UnsupportedOperationException.
    -->
    <color name="toolbar_title_color">@color/dark_default_text_color</color>
    <!-- Подсказки в outlined TextInputLayout / диалогах (ночь, AMOLED) -->
    <color name="dialog_textinput_hint">@color/dark_second_text_color</color>
    <color name="support_author_link_text">#64B5F6</color>

