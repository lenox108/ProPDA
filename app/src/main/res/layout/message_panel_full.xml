<?xml version="1.0" encoding="utf-8"?>
<!-- Вертикальная колонка: поле занимает оставшееся место, BBCode и кнопки всегда выше IME (padding на CardView). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipChildren="true"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/message_wrapper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="true"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <forpdateam.ru.forpda.ui.views.CodeEditor
                android:id="@+id/message_field"
                style="@style/Widget.ForPDA.CodeEditor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="@string/msg_panel_hint_message"
                android:imeOptions="flagNoFullscreen"
                android:inputType="textCapSentences|textMultiLine"
                android:minHeight="@dimen/dp48"
                android:padding="@dimen/content_padding_horizontal"
                android:textSize="@dimen/list_topic_title_text_size" />

            <ProgressBar
                android:id="@+id/form_load_progress"
                android:layout_width="@dimen/dp48"
                android:layout_height="@dimen/dp48"
                android:layout_gravity="center"
                android:contentDescription="@string/loading_data"
                android:visibility="gone" />
        </FrameLayout>

    </ScrollView>

    <RelativeLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_advanced_input"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/msg_panel_advanced_bbcode_desc"
            app:srcCompat="@drawable/ic_add" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_attachments"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_marginStart="@dimen/message_panel_button_overlap"
            android:layout_toEndOf="@+id/button_advanced_input"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/attachments"
            app:srcCompat="@drawable/ic_attachment" />

        <TextView
            android:id="@+id/attachment_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/button_attachments"
            android:layout_alignEnd="@id/button_attachments"
            android:layout_marginTop="@dimen/content_spacing"
            android:layout_marginEnd="@dimen/content_spacing_half"
            android:background="@drawable/notify_dot_menu"
            android:gravity="center"
            android:importantForAccessibility="no"
            android:maxLines="1"
            android:minWidth="@dimen/dp16"
            android:minHeight="@dimen/dp16"
            android:paddingStart="@dimen/content_spacing_half"
            android:paddingEnd="@dimen/content_spacing_half"
            tools:text="1"
            android:textColor="@color/white"
            android:textSize="@dimen/news_list_compat_meta_text_size"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_edt_poll"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_marginStart="@dimen/message_panel_button_overlap"
            android:layout_toEndOf="@+id/button_attachments"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/poll"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_poll_box" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_full"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_marginStart="@dimen/message_panel_button_overlap"
            android:layout_toEndOf="@+id/button_edt_poll"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/full_form"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_fullscreen" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_clear_message"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_toStartOf="@+id/button_preview"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/msg_panel_clear_message"
            app:srcCompat="@drawable/ic_clear" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_preview"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_toStartOf="@+id/send_container"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/msg_panel_preview"
            app:srcCompat="@drawable/ic_visibility" />

        <FrameLayout
            android:id="@+id/send_container"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_alignParentEnd="true">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/button_send"
                android:layout_width="@dimen/dp48"
                android:layout_height="@dimen/dp48"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/send_message"
                app:srcCompat="@drawable/ic_send" />

            <ProgressBar
                android:id="@+id/send_progress"
                android:layout_width="@dimen/dp48"
                android:layout_height="@dimen/dp48"
                android:clickable="false"
                android:contentDescription="@string/send_message"
                android:padding="@dimen/dp8"
                android:visibility="gone" />
        </FrameLayout>
    </RelativeLayout>
</LinearLayout>
