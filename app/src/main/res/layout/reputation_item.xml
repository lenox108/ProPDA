<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingBottom="@dimen/content_padding_vertical"
    android:paddingEnd="@dimen/content_padding_horizontal"
    android:paddingStart="@dimen/content_padding_horizontal"
    android:paddingTop="@dimen/content_padding_vertical">


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/rep_item_title"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/rep_item_image"
        android:textColor="?attr/colorOnSurface"
        android:textSize="@dimen/list_topic_title_text_size"
        tools:text="@string/test_topic_title"/>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/rep_item_image"
        android:layout_width="@dimen/dp16"
        android:layout_height="@dimen/dp16"
        android:layout_alignParentEnd="true" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/rep_item_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rep_item_title"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="@dimen/list_topic_meta_text_size"
        tools:text="@string/test_topic_description"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/rep_item_last_nick"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rep_item_desc"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="@string/test_nick"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/rep_item_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/rep_item_desc"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="@string/test_topic_date"/>

</RelativeLayout>