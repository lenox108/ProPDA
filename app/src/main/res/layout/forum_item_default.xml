<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:foreground="?attr/selectableItemBackgroundBorderless">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/forum_item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/content_block_padding_vertical"
        android:layout_marginEnd="@dimen/dp0"
        android:layout_marginStart="@dimen/content_padding_horizontal"
        android:layout_marginTop="@dimen/content_block_padding_vertical"
        android:layout_toStartOf="@+id/forum_item_icon"
        tools:text="@string/test_forum_title"
        android:textSize="@dimen/list_topic_title_text_size"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/forum_item_icon"
        android:layout_width="@dimen/list_avatar_compact_size"
        android:layout_height="@dimen/list_avatar_compact_size"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_margin="@dimen/content_padding_vertical" />
</RelativeLayout>