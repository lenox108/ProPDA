<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp56"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/selectableItemBackground">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/qms_contact_avatar"
        android:layout_width="@dimen/list_avatar_two_line_size"
        android:layout_height="@dimen/list_avatar_two_line_size"
        android:layout_marginBottom="@dimen/content_spacing"
        android:layout_marginStart="@dimen/content_padding_horizontal"
        android:layout_marginTop="@dimen/content_spacing"
        android:scaleType="centerCrop" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/qms_contact_nick"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/list_row_with_avatar_text_margin_start"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/qms_contact_count"
        android:textColor="?attr/default_text_color"
        tools:text="@string/test_nick"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/qms_contact_count"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/list_avatar_compact_size"
        android:minWidth="@dimen/list_avatar_compact_size"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/content_padding_horizontal"
        android:background="?count_background"
        android:paddingEnd="@dimen/content_spacing"
        android:paddingStart="@dimen/content_spacing"
        tools:text="@string/test_count_number"
        android:gravity="center"
        android:textColor="?attr/contrast_text_color"
        android:textStyle="bold"/>


</RelativeLayout>