<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/measure_root_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">
        <!--
            Эта вьюха нужна для различных измерений
        -->
        <View
            android:id="@+id/measure_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Контейнер вкладок: только фрагменты. Верх/низ — padding из MainActivity (таббар совпадает с peek BottomDrawer). -->
    <!-- background_for_lists: с системным nav, нижним sheet и подложкой темы (см. ThemeWebController); без ступени cards vs base/AMOLED #000. -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/fragments_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/background_for_lists"
        android:fitsSystemWindows="false">
    </androidx.coordinatorlayout.widget.CoordinatorLayout>


    <!--
        Для измерения размеров статусбара и навбара.
        От версии андроида эта хрень работает по-разному. Но в целом вроде норм.
    -->
    <View
        android:id="@+id/view_for_measure"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Полноэкранный scrim под раскрытый sheet; fits=false — как у фрагментов, без лишнего смещения под cutout. -->
    <View
        android:id="@+id/bottomMenuFade"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false"
        android:importantForAccessibility="no" />

    <!-- Нижний sheet + таббар: insets (навигация / жесты) только в коде — см. BottomDrawer + MainActivity. -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/bottomMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="false" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/bottomToggleArrow"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_gravity="top|center_horizontal"
            android:translationY="-35dp"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/bottom_nav_toggle_open_tabs"
            android:focusable="true"
            android:scaleType="center"
            android:visibility="gone"
            app:layout_anchor="@id/bottom_sheet2"
            app:layout_anchorGravity="top|center_horizontal"
            app:srcCompat="@drawable/ic_arrow_up"
            app:tint="?colorAccent"
            tools:visibility="visible" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_sheet2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_behavior="forpdateam.ru.forpda.ui.views.control.BottomSheetBehaviorFixed">

            <!-- Иконки — у нижнего края листа: peek bottom sheet показывает НИЗ контента, иначе при
                 раскрытии в полоске оказывались «хвост» списка/кнопка, а не иконки; fitToContents
                 давал collapsedOffset == expandedOffset и анимация пропадала. -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bottomMenuRecycler"
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_nav_tab_bar_height"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/bottom_nav_recycler_padding_horizontal"
                android:paddingEnd="@dimen/bottom_nav_recycler_padding_horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bottomCloseAllTabs"
                tools:layoutManager="GridLayoutManager"
                tools:listitem="@layout/item_bottom_tab"
                tools:spanCount="5" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bottomMenuLinkContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent">

                <EditText
                    android:id="@+id/bottomMenuLinkText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:autofillHints="url"
                    android:background="@android:color/transparent"
                    android:hint="@string/main_link_hint"
                    android:inputType="text|textWebEmailAddress"
                    android:minHeight="@dimen/dp48"
                    android:paddingStart="@dimen/list_row_padding_horizontal"
                    android:paddingTop="@dimen/list_row_padding_vertical"
                    android:paddingEnd="@dimen/list_row_padding_horizontal"
                    android:paddingBottom="@dimen/list_row_padding_vertical"
                    android:textSize="@dimen/list_topic_title_text_size"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/bottomMenuLinkIcon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/bottomMenuLinkIcon"
                    android:layout_width="@dimen/dp48"
                    android:layout_height="@dimen/dp48"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/open_link"
                    android:scaleType="center"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_open_in_new" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- В COLLAPSED peek = высота панели + inset навбара; без gone эта секция «просвечивает» под иконками (HyperOS и др.). -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/bottomMenu_view_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/list_row_padding_horizontal"
                android:paddingTop="@dimen/content_block_padding_vertical"
                android:paddingEnd="@dimen/list_row_padding_horizontal"
                android:paddingBottom="@dimen/content_block_padding_vertical"
                android:text="@string/bottom_nav_open_tabs_section"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/list_topic_meta_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/bottomMenuLinkContainer" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bottomTabsRecycler"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/content_spacing"
                android:visibility="gone"
                app:layout_constrainedHeight="true"
                app:layout_constraintBottom_toTopOf="@id/bottomCloseAllTabs"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_default="wrap"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bottomMenu_view_tabs"
                tools:itemCount="1"
                tools:listitem="@layout/drawer_tab_item" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/bottomCloseAllTabs"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:foreground="?selectableItemBackground"
                android:gravity="end|center_vertical"
                android:paddingStart="@dimen/list_row_padding_horizontal"
                android:paddingEnd="@dimen/list_row_padding_horizontal"
                android:text="@string/close_other_tabs"
                android:textColor="?attr/colorOnSurface"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/bottomMenuRecycler"
                app:layout_constraintTop_toBottomOf="@id/bottomTabsRecycler" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</RelativeLayout>
