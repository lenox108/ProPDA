<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?background_for_lists"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dp32">

        <ImageView
            android:layout_width="@dimen/profile_toolbar_avatar_size"
            android:layout_height="@dimen/profile_toolbar_avatar_size"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/icon_webview" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp24"
            android:gravity="center"
            android:text="Компонент Android System Webview не найден"
            android:textSize="@dimen/profile_stat_value_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nougatplus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp24"
            android:visibility="gone" />

        <Button
            android:id="@+id/wv_try_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dp24"
            android:text="Попробовать запустить" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="или"
            android:textSize="@dimen/empty_state_title_text_size" />

        <ImageView
            android:id="@+id/get_in_gp"
            android:layout_width="@dimen/webview_not_found_gp_badge_width"
            android:layout_height="@dimen/dp64"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dp16"
            android:src="@drawable/icon_get_in_gp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="или"
            android:textSize="@dimen/empty_state_title_text_size" />

        <ImageView
            android:id="@+id/get_in_4pda"
            android:layout_width="@dimen/dp64"
            android:layout_height="@dimen/dp64"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dp16"
            android:src="@drawable/icon_4pda" />
    </LinearLayout>
</ScrollView>
