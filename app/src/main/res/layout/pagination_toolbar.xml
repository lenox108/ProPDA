<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.tabs.TabLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tabs"
    android:layout_width="match_parent"
    android:layout_height="@dimen/pagination_toolbar_compact_height"
    android:layout_gravity="bottom"
    android:layout_marginStart="@dimen/dp0"
    android:layout_marginEnd="@dimen/dp0"
    android:layout_marginTop="?attr/actionBarSize"
    android:layout_marginBottom="@dimen/dp0"
    android:background="@android:color/transparent"
    android:contentDescription="@string/pagination_select_desc"
    android:elevation="0dp"
    android:visibility="gone"
    app:elevation="0dp"
    app:layout_collapseMode="pin"
    app:tabGravity="fill"
    app:tabIndicatorHeight="@dimen/dp0"
    app:tabIndicatorColor="@android:color/transparent"
    app:tabMode="fixed"
    app:tabPaddingEnd="@dimen/dp0"
    app:tabPaddingStart="@dimen/dp0"
    app:tabTextAppearance="@style/TextAppearance.ForPDA.PaginationPage"
    app:tabIconTint="@null"
    app:tabSelectedTextColor="?attr/colorOnSurface"
    app:tabTextColor="?attr/colorOnSurface" />