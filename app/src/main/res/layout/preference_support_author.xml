<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:clipToPadding="false"
    android:focusable="true"
    android:foreground="?selectableItemBackground"
    android:gravity="center"
    android:minHeight="@dimen/dp48"
    android:orientation="vertical"
    android:paddingStart="@dimen/content_padding_horizontal"
    android:paddingEnd="@dimen/content_padding_horizontal">

    <TextView
        android:id="@android:id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/pref_plate_single"
        android:ellipsize="end"
        android:gravity="center"
        android:minHeight="@dimen/dp40"
        android:paddingStart="@dimen/dp20"
        android:paddingTop="@dimen/dp10"
        android:paddingEnd="@dimen/dp20"
        android:paddingBottom="@dimen/dp10"
        android:singleLine="true"
        android:textAppearance="?textAppearanceListItem"
        android:textColor="?default_text_color"
        android:textSize="@dimen/list_topic_title_text_size" />

    <TextView
        android:id="@android:id/summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="?second_text_color"
        android:textSize="@dimen/list_topic_meta_text_size"
        android:visibility="gone" />

    <LinearLayout
        android:id="@android:id/widget_frame"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <View
        android:id="@+id/prefRowDivider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_thin"
        android:background="?divider_line"
        android:visibility="gone" />

</LinearLayout>
