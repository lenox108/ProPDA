<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimary"
    android:orientation="vertical"
    android:paddingStart="@dimen/dp16"
    android:paddingEnd="@dimen/dp16"
    android:paddingTop="@dimen/dp12"
    android:paddingBottom="@dimen/dp12">

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_thin"
        android:layout_marginBottom="@dimen/dp8"
        android:background="?attr/colorOutlineVariant" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/write"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/button_hide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close"
            android:src="@drawable/ic_arrow_down"
            app:tint="?attr/icon_base" />
    </LinearLayout>

    <EditText
        android:id="@+id/message_field"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:autofillHints="message"
        android:background="@android:color/transparent"
        android:gravity="top"
        android:hint="@string/chat_creator_enter_message"
        android:imeOptions="flagNoFullscreen"
        android:inputType="textCapSentences|textMultiLine"
        android:maxLines="10"
        android:minLines="3"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOnSurfaceVariant"
        android:textSize="@dimen/list_topic_title_text_size" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <ProgressBar
            android:id="@+id/send_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp8"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_send"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/send"
            android:textColor="?attr/colorSecondary"
            app:icon="@drawable/ic_send"
            app:iconPadding="@dimen/dp8"
            app:iconTint="?attr/colorSecondary" />
    </LinearLayout>

</LinearLayout>
