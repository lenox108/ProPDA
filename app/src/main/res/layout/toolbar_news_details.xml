<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ProgressBar
        android:id="@+id/article_progress_bar"
        android:layout_width="@dimen/dp48"
        android:layout_height="@dimen/dp48"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <forpdateam.ru.forpda.ui.views.AspectRatioImageView
        android:id="@+id/article_image"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:aspectRatio="0.75"
        app:layout_collapseMode="parallax"
        tools:src="@drawable/test_img"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingBottom="@dimen/content_padding_vertical"
        android:paddingEnd="@dimen/content_padding_horizontal"
        android:paddingStart="@dimen/content_padding_horizontal"
        android:paddingTop="@dimen/content_padding_vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/article_title"
            style="?ProfileToolbarTextStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:singleLine="false"
            android:textSize="@dimen/profile_stat_value_text_size"
            android:textStyle="bold"
            tools:text="asuiodauspoudioauiosdupoiausioudoiauopisuoiduaiouspodiuaopsudoaipusoai"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp8"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/article_nick"
                style="?ProfileToolbarTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/list_topic_meta_text_size"
                android:textStyle="bold"
                tools:text="LONG NICK"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/article_comments_count"
                style="?ProfileToolbarTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/content_padding_horizontal"
                android:textSize="@dimen/list_topic_meta_text_size"
                android:textStyle="bold"
                tools:text="2560"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/article_date"
                style="?ProfileToolbarTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:textSize="@dimen/list_topic_meta_text_size"
                android:textStyle="bold"
                tools:text="LONG NICK"/>
        </LinearLayout>


    </LinearLayout>

</FrameLayout>