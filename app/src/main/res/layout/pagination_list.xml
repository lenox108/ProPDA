<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.tabs.TabLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tabs"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp48"
    android:layout_gravity="bottom"
    android:layout_marginBottom="@dimen/content_spacing"
    android:layout_marginTop="@dimen/content_spacing"
    android:background="?colorPrimary"
    android:elevation="@dimen/card_elevation"
    android:visibility="gone"
    app:tabGravity="fill"
    app:tabIndicatorHeight="@dimen/dp0"
    app:tabIndicatorColor="@android:color/transparent"
    app:tabMode="fixed"
    app:tabPaddingEnd="@dimen/dp0"
    app:tabPaddingStart="@dimen/dp0"
    app:tabIconTint="@null"
    app:tabSelectedTextColor="?attr/default_text_color"
    app:tabTextColor="?attr/default_text_color" />