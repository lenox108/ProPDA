<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile_block_about"
    style="@style/CardStyle.Item.Wide"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp48">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_title"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp48"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/item_date"
                android:gravity="center_vertical"
                android:paddingEnd="@dimen/content_padding_horizontal"
                android:paddingStart="@dimen/content_padding_horizontal"
                android:text="@string/profile_title_about"
                android:textColor="?attr/default_text_color"
                android:textSize="@dimen/list_topic_meta_text_size"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_date"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp48"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:paddingEnd="@dimen/content_padding_horizontal"
                android:paddingStart="@dimen/content_padding_horizontal"
                tools:text="@string/test_topic_date"
                android:textColor="?attr/second_text_color"
                android:textSize="@dimen/list_topic_meta_text_size" />
        </RelativeLayout>


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/item_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:paddingBottom="@dimen/content_block_padding_vertical"
            android:paddingEnd="@dimen/content_padding_horizontal"
            android:paddingStart="@dimen/content_padding_horizontal"
            android:text="ajskldjklasjdlkajls;kjdklk;asd"
            android:textSize="@dimen/list_topic_title_text_size" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp48">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/item_dislike_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/content_spacing"
                android:drawablePadding="@dimen/content_spacing"
                android:enabled="false"
                android:minWidth="@dimen/dp48"
                android:text="1" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/item_like_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@+id/item_dislike_btn"
                android:drawablePadding="@dimen/content_spacing"
                android:enabled="false"
                android:minWidth="@dimen/dp48"
                android:text="1" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_rating"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp32"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/content_padding_horizontal"
                android:gravity="center"
                android:minWidth="@dimen/dp32"
                android:paddingEnd="@dimen/bottom_tab_badge_padding_horizontal"
                android:paddingStart="@dimen/bottom_tab_badge_padding_horizontal"
                android:text="10"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </RelativeLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>