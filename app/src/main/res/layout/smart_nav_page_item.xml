<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp48"
    android:paddingStart="@dimen/dp8"
    android:paddingEnd="@dimen/dp8"
    android:paddingTop="@dimen/dp2"
    android:paddingBottom="@dimen/dp2">

    <LinearLayout
        android:id="@+id/smart_nav_page_row"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/transparent"
        android:paddingStart="@dimen/dp6"
        android:paddingEnd="@dimen/dp6">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/smart_nav_page_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center_vertical|start"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/smart_nav_page_current_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smart_nav_current_page"
            android:textSize="11sp"
            android:textColor="?attr/colorAccent"
            android:visibility="gone"/>
    </LinearLayout>

</FrameLayout>
