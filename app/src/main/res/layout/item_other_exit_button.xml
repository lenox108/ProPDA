<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/otherExitButton"
        android:layout_width="@dimen/dp56"
        android:layout_height="@dimen/dp56"
        android:layout_gravity="center_horizontal"
        android:clickable="true"
        android:contentDescription="@string/menu_item_exit"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="?attr/cards_background"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/list_plate_stroke_color"
        app:strokeWidth="?attr/list_plate_stroke_width">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/otherExitIcon"
                android:layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                android:contentDescription="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_power_settings_new"
                app:tint="?attr/icon_base"
                tools:ignore="ImageContrastCheck" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
