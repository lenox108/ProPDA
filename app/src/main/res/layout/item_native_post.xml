<?xml version="1.0" encoding="utf-8"?>
<!--
  Native topic renderer post card (roadmap native-topic-renderer.md, Фаза 1).
  Transparent OUTER wrapper so the «Страница N» divider renders in the neutral gap BETWEEN cards
  (on the list background, WebView parity) — NOT inside the post card's surface. The inner
  native_post_card carries the surface background, margins, padding and all the post content.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/native_post_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- «Страница N» divider — shown above the first post of each newly loaded page (hybrid infinite
         scroll), matching the WebView page separators. Lives on the TRANSPARENT wrapper so it sits in
         the neutral gap between cards, not on a card's surface. GONE for posts mid-page. -->
    <TextView
        android:id="@+id/native_post_page_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        tools:text="Страница 3" />

    <!-- The post card itself: a rounded, slightly elevated Material 3 card. Background (rounded
         GradientDrawable), corner radius and elevation are applied in the ViewHolder so the highlight
         fade can animate the card colour while keeping the rounded corners. -->
    <LinearLayout
        android:id="@+id/native_post_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="4dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Topic-hat toggle bar («ШАПКА ТЕМЫ ▾/▴»). For the hat post the adapter shows this ABOVE the
             author header (WebView parity: the hat_button sits outside/above the collapsible hat_content),
             so the whole post below is the collapsible region. GONE for ordinary posts. -->
        <LinearLayout
            android:id="@+id/native_post_hat_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone" />

        <!-- Header: [avatar+rep] [nick / group / 💬count]  [date, #N ⋮] — layout parity with WebView. -->
        <LinearLayout
            android:id="@+id/native_post_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:clipChildren="false">

            <!-- Avatar. Reputation used to be overlaid here as a corner badge; it now lives on the stats
                 row (★ rep · 💬 posts) beside the group, so the avatar stays clean.
                 layout_gravity=center_vertical: the avatar is shorter than the nick/group/stats column,
                 so with the header's top gravity it would hug the card's upper edge. Centring it against
                 the text column keeps the header symmetric; the child gravity wins over the parent's. -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical">

                <ImageView
                    android:id="@+id/native_post_avatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <!-- Nick row. In the CLASSIC header only the nick is visible here and the date lives in
                     the right-hand column. In the MODERN header (theme.modern_post_header) the right
                     column is GONE and the date + ⋮ move onto this row, beside the nick. ConstraintLayout
                     (not LinearLayout) because the nick must hug the date on short nicks yet ellipsize —
                     not push the date off-screen — on long ones: constrainedWidth + a packed, start-biased
                     chain gives exactly that, while ⋮ stays pinned to the end. -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/native_post_nick_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/native_post_nick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="?attr/colorOnSurface"
                        app:layout_constrainedWidth="true"
                        app:layout_constraintHorizontal_bias="0"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/native_post_date_inline"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:text="SnapshotUser" />

                    <!-- Relative date («17 ч.») — MODERN only, GONE in the classic header. -->
                    <TextView
                        android:id="@+id/native_post_date_inline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        app:layout_constraintStart_toEndOf="@+id/native_post_nick"
                        app:layout_constraintEnd_toStartOf="@+id/native_post_menu_inline"
                        app:layout_constraintBaseline_toBaselineOf="@+id/native_post_nick"
                        tools:text="17 ч."
                        tools:visibility="visible" />

                    <!-- Post menu — MODERN only (the classic header has its own ⋮ in the right column). -->
                    <!-- Height tied to the nick (0dp between the nick's top/bottom) so the 30dp-ish icon
                         doesn't inflate the wrap-content nick row and push the group line down — that made
                         the nick→group gap read taller than the group→count gap. Width keeps a 30dp touch
                         target; the icon centres on the nick. -->
                    <ImageView
                        android:id="@+id/native_post_menu_inline"
                        android:layout_width="30dp"
                        android:layout_height="0dp"
                        android:padding="4dp"
                        android:contentDescription="@string/menu"
                        android:src="@drawable/ic_more_vert"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/native_post_nick"
                        app:layout_constraintBottom_toBottomOf="@+id/native_post_nick"
                        tools:visibility="visible" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Author group (tinted by server groupColor) — parity with WebView .group_text. -->
                <TextView
                    android:id="@+id/native_post_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:includeFontPadding="false"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="Постоянный" />

                <!-- Stats row: reputation (★ N) then the author's forum post count (💬 N). Reputation
                     moved off the avatar to here (user request); it binds immediately, the post count
                     arrives via deferred enrichment. GONE in super-compact (single-line header). -->
                <LinearLayout
                    android:id="@+id/native_post_stats_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Reputation (★ N) — parity with WebView .reputation. Tap → reputation history. -->
                    <TextView
                        android:id="@+id/native_post_rep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:drawablePadding="4dp"
                        android:gravity="center_vertical"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="442"
                        tools:visibility="visible" />

                    <!-- Author's forum post count (💬 N) — parity with WebView user_post_count. The
                         leading gap (separating it from reputation) is applied in code so it collapses
                         to 0 when reputation is absent. -->
                    <TextView
                        android:id="@+id/native_post_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:drawablePadding="4dp"
                        android:gravity="center_vertical"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="2846"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right column (CLASSIC header): date on top, then post number + three-dots menu (parity
                 with WebView). GONE under theme.modern_post_header — there the date and ⋮ live inline on
                 the nick row instead. -->
            <LinearLayout
                android:id="@+id/native_post_right_column"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/native_post_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="20.05.2026, 14:55" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/native_post_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="#21" />

                    <!-- Three-dots post menu (parity with WebView .btn.inf.menu → showPostMenu). -->
                    <ImageView
                        android:id="@+id/native_post_menu"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="2dp"
                        android:padding="4dp"
                        android:contentDescription="@string/menu"
                        android:src="@drawable/ic_more_vert"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/native_post_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/native_post_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="Рейтинг: 5" />

        <LinearLayout
            android:id="@+id/native_post_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</LinearLayout>
