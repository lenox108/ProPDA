<?xml version="1.0" encoding="utf-8"?>
<!--
  Native topic renderer post card (roadmap native-topic-renderer.md, Фаза 1).
  Header (avatar + nick/group/date) + a vertical container the adapter fills with
  one child view per BodyBlock + a minimal footer (post number / rating).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/native_post_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="?attr/colorSurfaceContainer"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Avatar with the reputation number overlaid as a badge (parity with WebView .reputation). -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/native_post_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/native_post_rep_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="-3dp"
                android:layout_marginEnd="-3dp"
                android:background="@drawable/bg_post_rep_badge"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:minWidth="16dp"
                android:gravity="center"
                tools:text="28" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/native_post_nick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                tools:text="SnapshotUser" />

            <TextView
                android:id="@+id/native_post_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Постоянный · 20.05.2026" />
        </LinearLayout>

        <!-- Author's forum post count (💬 N) — parity with WebView user_post_count. -->
        <TextView
            android:id="@+id/native_post_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:drawablePadding="3dp"
            android:gravity="center_vertical"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:text="2846"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/native_post_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="#21" />

        <!-- Three-dots post menu (parity with WebView .btn.inf.menu → showPostMenu). -->
        <ImageView
            android:id="@+id/native_post_menu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="2dp"
            android:padding="4dp"
            android:contentDescription="@string/menu"
            android:src="@drawable/ic_more_vert"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/native_post_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/native_post_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="Рейтинг: 5" />

    <LinearLayout
        android:id="@+id/native_post_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="?attr/colorOutlineVariant" />
</LinearLayout>
