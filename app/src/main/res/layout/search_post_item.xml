<?xml version="1.0" encoding="utf-8"?>
<!--
  Результат «поиск по сообщениям форума» — скруглённая M3-карточка, вписанная с отступом (паритет с
  постами нативной темы item_native_post: тот же content_card_surface, лёгкий подъём и скругление).
  Раньше использовался CardStyle.Item.Wide (cardCornerRadius=0dp, edge-to-edge) — из-за него выдача
  постов выглядела плоской «без M3». Вертикальные промежутки задаёт SpacingItemDecoration(dp8), поэтому
  на карточке только горизонтальный отступ.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/CardStyle.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/content_padding_vertical"
        android:paddingEnd="@dimen/content_padding_horizontal"
        android:paddingStart="@dimen/content_padding_horizontal"
        android:paddingTop="@dimen/content_padding_vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/search_post_topic_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/list_topic_meta_text_size"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Тема: OnePlus 15 — Обсуждение"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/content_spacing_half">

            <ImageView
                android:id="@+id/search_post_avatar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_person"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/search_post_nick"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="@dimen/list_topic_meta_text_size"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="claude.test"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/search_post_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/list_topic_meta_text_size"
                tools:text="Сегодня, 12:30"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/search_post_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/content_spacing_half"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
