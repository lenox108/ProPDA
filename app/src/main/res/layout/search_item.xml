<?xml version="1.0" encoding="utf-8"?>
<!--
  Результат поиска по темам — та же скруглённая M3-карточка, что и у выдачи по сообщениям
  (search_post_item). Раньше здесь стоял CardStyle.Item.Wide (cardCornerRadius=0dp, edge-to-edge),
  из-за чего режим «Темы» выглядел плоским «без M3». Вертикальные промежутки даёт
  SpacingItemDecoration(dp8), поэтому на карточке только горизонтальный отступ.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/CardStyle.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/content_padding_vertical"
        android:paddingEnd="@dimen/content_padding_horizontal"
        android:paddingStart="@dimen/content_padding_horizontal"
        android:paddingTop="@dimen/content_padding_vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/search_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/list_topic_title_text_size"
            android:textStyle="bold"
            tools:text="@string/test_topic_title"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/search_item_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/search_item_title"
            android:layout_marginTop="@dimen/content_spacing_half"
            android:ellipsize="end"
            android:maxLines="5"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/list_topic_meta_text_size"
            tools:text="@string/test_topic_description"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/search_item_last_nick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/search_item_content"
            android:layout_marginTop="@dimen/content_spacing_half"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/list_topic_meta_text_size"
            tools:text="@string/test_topic_last_nick"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/search_item_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_below="@+id/search_item_content"
            android:layout_marginTop="@dimen/content_spacing_half"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/list_topic_meta_text_size"
            tools:text="@string/test_topic_date"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
