<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom switch widget used by SwitchPreferenceCompat.

    SwitchMaterial (Material 2) draws a clean, compact switch — a circular
    elevated thumb over a thin rounded track — that is more compact than the
    large M3 MaterialSwitch and looks neat (unlike hand-rolled shape drawables,
    which clipped the thumb). Per-state colours are applied in
    SwitchPreference.onBind: androidx.preference can't resolve ?attr/* inside a
    ColorStateList at inflation, and the neutral theme's colorPrimary is
    literally white, so the ON colour is taken from colorAccent (the real,
    palette-aware accent). The literal fallbacks below cover the frame before
    bind.
-->
<com.google.android.material.switchmaterial.SwitchMaterial xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/switchWidget"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@null"
    android:clickable="false"
    android:focusable="false"
    app:thumbTint="@color/preference_switch_thumb_tint"
    app:trackTint="@color/preference_switch_track_tint" />
