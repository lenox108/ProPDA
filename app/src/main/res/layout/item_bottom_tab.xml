<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:minHeight="@dimen/bottom_tab_item_min_height"
    android:paddingTop="@dimen/bottom_tab_padding_top"
    android:paddingBottom="@dimen/bottom_tab_padding_bottom">

    <!-- Подложка для активного таба (pill shape) -->
    <View
        android:id="@+id/tabActiveBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="3dp"
        android:background="@drawable/bg_tab_active_pill"
        android:importantForAccessibility="no"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/itemBottomMenuIcon"
        app:layout_constraintEnd_toEndOf="@id/itemBottomMenuIcon"
        app:layout_constraintHeight_min="40dp"
        app:layout_constraintStart_toStartOf="@id/itemBottomMenuIcon"
        app:layout_constraintTop_toTopOf="@id/itemBottomMenuIcon"
        app:layout_constraintWidth_min="40dp" />

    <ImageView
        android:id="@+id/itemBottomMenuIcon"
        android:layout_width="@dimen/bottom_tab_icon_size"
        android:layout_height="@dimen/bottom_tab_icon_size"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/ic_newspaper" />

    <!-- Индикатор убран по требованию (no underline) -->

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/itemBottomMenuCounter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/bottom_tab_badge_margin_bottom"
        android:layout_marginStart="@dimen/bottom_tab_badge_margin_start"
        android:background="?attr/notify_dot_tab"
        android:gravity="center"
        android:maxLines="1"
        android:minHeight="@dimen/bottom_tab_badge_min_height"
        android:paddingStart="@dimen/bottom_tab_badge_padding_horizontal"
        android:paddingEnd="@dimen/bottom_tab_badge_padding_horizontal"
        android:text="1"
        android:textColor="@color/white"
        android:importantForAccessibility="no"
        android:visibility="visible"
        app:autoSizeMaxTextSize="@dimen/bottom_tab_badge_autosize_max_text_size"
        app:autoSizeMinTextSize="@dimen/bottom_tab_badge_autosize_min_text_size"
        app:autoSizeStepGranularity="@dimen/text_autosize_step_granularity_1sp"
        app:autoSizeTextType="uniform"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@id/itemBottomMenuIcon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:layout_constraintWidth_min="@dimen/bottom_tab_badge_min_width"
        tools:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
