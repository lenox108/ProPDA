<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp48"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/qms_theme_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/content_padding_horizontal"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/qms_theme_count"
        tools:text="@string/test_topic_title"
        android:textColor="?attr/default_text_color" />

    <TextView
        android:id="@+id/qms_theme_count"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/list_avatar_compact_size"
        android:minWidth="@dimen/list_avatar_compact_size"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:gravity="center"
        android:layout_marginEnd="@dimen/content_padding_horizontal"
        android:paddingStart="@dimen/content_spacing"
        android:paddingEnd="@dimen/content_spacing"
        android:background="?count_background"
        android:textColor="?attr/contrast_text_color"
        android:textStyle="bold"
        tools:text="@string/test_count_number" />

</RelativeLayout>