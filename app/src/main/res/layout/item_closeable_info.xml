<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:layout_marginVertical="@dimen/dp12">

    <ImageView
        android:id="@+id/infoItemIcon"
        android:layout_width="@dimen/list_avatar_compact_size"
        android:layout_height="@dimen/list_avatar_compact_size"
        android:layout_marginBottom="@dimen/dp12"
        android:layout_marginStart="@dimen/content_padding_horizontal"
        android:layout_marginTop="@dimen/dp12"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:srcCompat="@drawable/ic_info" />

    <TextView
        android:id="@+id/infoItemTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp12"
        android:layout_marginStart="@dimen/menu_icon_text_margin_start"
        android:layout_marginTop="@dimen/dp12"
        android:textColor="?default_text_color"
        android:textSize="@dimen/list_topic_meta_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/infoItemClose"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Favorites" />

    <ImageButton
        android:id="@+id/infoItemClose"
        style="@style/Widget.AppCompat.Button.Borderless.Colored"
        android:layout_width="@dimen/dp48"
        android:layout_height="@dimen/dp48"
        android:contentDescription="@string/close"
        android:padding="@dimen/dp12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:srcCompat="@drawable/ic_close" />

    <View
        android:id="@+id/infoItemRowDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_thin"
        android:layout_marginStart="@dimen/menu_icon_text_margin_start"
        android:background="?divider_line"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
