<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/background_for_cards">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/controls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                style="@style/CardStyle.Wide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp8"
                android:layout_marginTop="@dimen/dp8">

                <EditText
                    android:id="@+id/poll_title_field"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp48"
                    android:layout_marginBottom="@dimen/dp8"
                    android:layout_marginEnd="@dimen/content_padding_horizontal"
                    android:layout_marginStart="@dimen/content_padding_horizontal"
                    android:layout_marginTop="@dimen/dp8"
                    android:hint="@string/poll_title"
                    android:textSize="@dimen/list_topic_title_text_size" />

            </androidx.cardview.widget.CardView>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/poll_questions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


    <RelativeLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/divider_thin">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/poll_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp48"
            android:layout_toStartOf="@+id/add_poll"
            android:paddingEnd="@dimen/content_padding_horizontal"
            android:paddingStart="@dimen/content_padding_horizontal"
            android:text="@string/poll"
            android:textAllCaps="true"
            android:textStyle="bold" />


        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/add_poll"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@drawable/ic_toolbar_add" />
    </RelativeLayout>

</RelativeLayout>