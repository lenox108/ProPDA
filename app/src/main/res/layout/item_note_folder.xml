<?xml version="1.0" encoding="utf-8"?>
<!--
    Папка — такая же строка плашки, что и заметка (см. item_note.xml): фон, скругления и
    зазоры группы ставит NoteFolderAdapterDelegate через applyListRowPlate(), поэтому папка
    и её раскрытые заметки читаются одним блоком, как секции избранного.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="@dimen/note_folder_row_min_height"
    android:orientation="horizontal"
    android:paddingBottom="@dimen/note_row_padding_vertical"
    android:paddingEnd="@dimen/dp4"
    android:paddingStart="@dimen/list_row_padding_horizontal"
    android:paddingTop="@dimen/note_row_padding_vertical">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/itemChevron"
        android:layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        android:contentDescription="@null"
        android:src="@drawable/ic_toolbar_chevron_right" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/itemIcon"
        android:layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        android:layout_marginStart="@dimen/dp8"
        android:contentDescription="@null"
        android:src="@drawable/ic_note_folder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp12"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/itemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/list_topic_title_text_size"
            tools:text="Работа" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/itemCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/note_row_line_spacing"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/list_topic_meta_text_size"
            tools:text="12 закладок" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/itemMore"
        android:layout_width="@dimen/dp40"
        android:layout_height="@dimen/dp40"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/note_manage_folders"
        android:padding="@dimen/dp8"
        android:src="@drawable/ic_more_vert" />

</LinearLayout>
