<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingTop="@dimen/dp32"
    android:paddingBottom="@dimen/dp32"
    android:paddingStart="@dimen/dp24"
    android:paddingEnd="@dimen/dp24"
    android:clickable="true"
    android:background="?attr/selectableItemBackgroundBorderless">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/item_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/second_text_color"
        android:textAllCaps="true"
        android:textSize="@dimen/list_topic_meta_text_size" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/item_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/content_spacing_half"
        android:textColor="?attr/default_text_color"
        android:textSize="@dimen/profile_stat_value_text_size"
        android:textStyle="bold"/>
</LinearLayout>