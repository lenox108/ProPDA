<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile_block_about"
    style="@style/CardStyle.Item.Wide"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/item_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp48"
        android:gravity="center_vertical"
        android:paddingEnd="@dimen/content_padding_horizontal"
        android:paddingStart="@dimen/content_padding_horizontal"
        android:text="@string/profile_title_about"
        android:textColor="?attr/colorOnSurface"
        android:textSize="@dimen/list_topic_meta_text_size"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/item_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp48"
        android:gravity="top"
        android:paddingStart="@dimen/content_padding_horizontal"
        android:paddingEnd="@dimen/content_padding_horizontal"
        android:paddingBottom="@dimen/content_block_padding_vertical"
        android:textColor="?attr/colorOnSurface"
        android:textSize="@dimen/list_topic_title_text_size"
        tools:text="ajskldjklasjdlkajls;kjdklk;asd"/>
</androidx.cardview.widget.CardView>