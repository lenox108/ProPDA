    <!--
        Toolbar title color, выбирается автоматически по day/night.
        В values-night/colors.xml перекрыто на @color/dark_default_text_color.
        Используется как concrete-@color в fragment_base.xml (Fix A):
        XML-атрибут app:titleTextColor должен быть КОНКРЕТНЫМ, чтобы
        TypedArray.getColorStateList не получал TYPE_ATTRIBUTE — иначе
        Toolbar.<init> падает с UnsupportedOperationException.
    -->
    <color name="toolbar_title_color">@color/light_default_text_color</color>
    <!--
        Concrete (NON-?attr) value for CollapsingToolbarLayout title text color.
        The Material3 default collapsingToolbarLayoutStyle sets
        expanded/collapsedTitleTextColor to @macro/...headline_color, which expands
        inline to ?attr/colorOnSurface. Macros stay TYPE_ATTRIBUTE until resolved
        against the inflation context's theme; in the Material You path that
        context bottoms out at Theme.AppCompat.Empty where the app's colorOnSurface
        has no value, so TypedArray.getColorStateList throws
        UnsupportedOperationException at CollapsingToolbarLayout.<init> (styleable
        index 11 = expandedTitleTextColor). Setting the title colors directly on the
        view to this concrete color removes the ?attr indirection. The toolbars use
        titleEnabled=false, so this color is never actually rendered — it only needs
        to be a resolvable non-attribute value to satisfy the constructor.
    -->
    <color name="collapsing_toolbar_title_color">#000000</color>
