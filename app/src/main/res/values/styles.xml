        SHADOWS the activity-theme-level override defined in
        DayNightPreferenceTheme. PreferenceFragmentCompat reads
        ?attr/preferenceTheme and uses that overlay's attributes when
        inflating preferences, so we must override the attribute here too,
        otherwise our custom widgetLayout never reaches the SwitchCompat.
    -->
    <style name="PreferenceThemeOverlay.ForPDA" parent="PreferenceThemeOverlay">
        <item name="switchPreferenceCompatStyle">@style/SwitchPreferenceCompatStyle</item>
    </style>

    <style name="DayNightPreferenceTheme" parent="DayNightAppTheme">
        <item name="switchPreferenceCompatStyle">@style/SwitchPreferenceCompatStyle</item>
        <!--<item name="textAppearanceListItem">@style/CodeFont</item>
        <item name="android:textAppearanceListItem">@style/CodeFont</item>
        <item name="textAppearanceListItemSmall">@style/CodeFont</item>
        <item name="android:textAppearanceListItemSmall">@style/CodeFont</item>-->
        <!--<item name="android:listDivider">@color/md_amber_800</item>
        <item name="android:dividerHeight">1dp</item>-->
    </style>

    <!--
        AMOLED THEME - Fallback in values/ to prevent Resources$NotFoundException
        Overridden in values-night/styles.xml with actual AMOLED colors
    -->
    <style name="AmoledAppTheme" parent="DayNightAppTheme">
        <!-- Base fallback - will be overridden by values-night -->
        <item name="colorControlNormal">?icon_toolbar</item>
        <item name="android:colorControlNormal">?icon_toolbar</item>
        <item name="actionBarTheme">@style/AmoledAppTheme.AppBarOverlay</item>
        <item name="toolbarStyle">@style/ToolbarStyle.Light</item>
    </style>

    <style name="AmoledAppTheme.NoActionBarBase" parent="AmoledAppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/light_navigation_bar_color</item>
    </style>

    <style name="AmoledAppTheme.NoActionBar" parent="AmoledAppTheme.NoActionBarBase" />

    <style name="AmoledAppTheme.AppBarOverlay" parent="DayNightAppTheme.AppBarOverlay" />
    <style name="AmoledAppTheme.PopupOverlay" parent="DayNightAppTheme.PopupOverlay" />
    <style name="AmoledAppTheme.Dialog" parent="DayNightAppTheme.Dialog" />
    <style name="AmoledAppTheme.BottomSheetDialog" parent="DayNightAppTheme.BottomSheetDialog" />


    <!-- OTHER -->
    <style name="CodeFont">
        <item name="android:textColor">#00FF00</item>
        <item name="android:typeface">monospace</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="OverFlow" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">?icon_toolbar</item>
    </style>

    <style name="Widget.ForPDA.CodeEditor" parent="Widget.AppCompat.EditText">
        <item name="android:textCursorDrawable">@drawable/text_cursor</item>
        <item name="android:textSelectHandle">@drawable/text_select_handle</item>
        <item name="android:textSelectHandleLeft">@drawable/text_select_handle_left</item>
        <item name="android:textSelectHandleRight">@drawable/text_select_handle_right</item>
    </style>

    <style name="Widget.ForPDA.TextSelectHandleWindow" parent="@android:style/Widget.PopupWindow">
        <item name="android:popupBackground">@android:color/transparent</item>
    </style>

    <style name="Widget.ForPDA.PopupWindow" parent="Widget.AppCompat.PopupWindow">
        <item name="android:popupBackground">@drawable/bg_popup_menu_m3</item>
    </style>

    <style name="Widget.ForPDA.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu_m3</item>
        <item name="android:colorBackground">?attr/cards_background</item>
        <item name="android:textColorPrimary">?attr/default_text_color</item>
        <item name="android:textColorSecondary">?attr/second_text_color</item>
    </style>

    <style name="Widget.ForPDA.PopupMenu.Overflow" parent="Widget.ForPDA.PopupMenu" />

    <style name="Widget.ForPDA.ListPopupWindow" parent="Widget.AppCompat.ListPopupWindow">
        <item name="android:popupBackground">@drawable/bg_popup_menu_m3</item>
        <item name="android:dropDownListViewStyle">@style/Widget.ForPDA.DropDownListView</item>
    </style>

    <style name="Widget.ForPDA.DropDownListView" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:cacheColorHint">@android:color/transparent</item>
        <item name="android:listSelector">?attr/selectableItemBackground</item>
        <item name="android:divider">@android:color/transparent</item>
        <item name="android:dividerHeight">0dp</item>
    </style>

    <style name="actionModeCloseButtonStyle" parent="Widget.AppCompat.Light.ActionButton.CloseMode">
        <item name="android:tint">?icon_toolbar</item>
    </style>

    <style name="MyTextViewStyle" parent="android:Widget.TextView">
        <item name="android:textColor">?default_text_color</item>
        <item name="android:fontFamily">?android:fontFamily</item>
    </style>

    <style name="ProfileToolbarTextStyle">
        <item name="android:textColorLink">?link_color_contrast</item>
        <item name="android:textColor">?link_color_contrast</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">5</item>
        <item name="android:shadowColor">#4c000000</item>
        <!--<item name="android:textAlignment" tools:ignore="NewApi">center</item>-->
    </style>

    <!-- RadioButton: выбранный кружок должен быть виден — используем colorAccent вместо colorPrimary -->
    <style name="Widget.ForPDA.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="colorPrimary">?attr/colorAccent</item>
        <item name="colorOnSurface">?attr/second_text_color</item>
    </style>

    <style name="Widget.ForPDA.DialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:minHeight">@dimen/dp40</item>
        <item name="android:minWidth">@dimen/dp64</item>
        <item name="android:paddingStart">@dimen/dp16</item>
        <item name="android:paddingEnd">@dimen/dp16</item>
        <item name="android:textColor">?attr/link_color</item>
    </style>

    <style name="CardStyle.Item" parent="CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">?cards_background</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <style name="CardStyle.Item.Wide" parent="CardStyle.Item">
        <item name="android:layout_marginLeft">@dimen/card_margin_horizontal</item>
        <item name="android:layout_marginRight">@dimen/card_margin_horizontal</item>
        <item name="cardCornerRadius">0dp</item>
    </style>

    <style name="CardStyle.Wide" parent="CardStyle.Item.Wide">
        <item name="android:layout_marginBottom">@dimen/dp8</item>
    </style>


    <!--<style name="ButtonsOnWhite">
        <item name="colorControlNormal">#757575</item>
        <item name="colorControlActivated">@color/light_colorAccent</item>
    </style>-->


    <style name="ImageViewTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus" tools:ignore="NewApi">true</item>
        <item name="android:windowTranslucentNavigation" tools:ignore="NewApi">true</item>
    </style>

    <style name="ImageViewTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:singleLine">true</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="ImageViewTheme.PopupOverlay" parent="ThemeOverlay.Material3.Dark">
        <item name="elevation">0dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="MessagePanelAdvancedTabText" parent="TextAppearance.Material3.LabelLarge">
        <!-- Иначе LabelLarge тянет colorPrimary — на тёмном colorPrimary таб «сливается» с фоном -->
        <item name="fontFamily">?fontFamily</item>
        <item name="android:fontFamily">?android:fontFamily</item>
        <item name="android:textColor">?attr/default_text_color</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="ShapeAppearance.ForPDA.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>
    <style name="ShapeAppearance.ForPDA.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <!-- Верхние углы bottom sheet как у iOS (~16pt) -->
    <style name="ShapeAppearance.ForPDA.BottomSheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    <!-- Нижняя панель вкладок / drawer: как pref_plate / list_plate_corner_radius (~card_corner_radius) -->
    <style name="ShapeAppearance.ForPDA.BottomNavBar" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/list_plate_corner_radius</item>
        <item name="cornerSizeTopRight">@dimen/list_plate_corner_radius</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
