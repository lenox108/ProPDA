    </style>

    <!--
        Inherits from the Material variant so it keeps the same row metrics
        (paddings, icon space, etc.) as the rest of the preference list.
        Only the switch widget itself is replaced via android:widgetLayout
        so we control the SwitchCompat tints explicitly.
    -->
    <style name="SwitchPreferenceCompatStyle" parent="Preference.SwitchPreferenceCompat.Material">
        <item name="android:widgetLayout">@layout/preference_widget_switch_forpda</item>
    </style>

    <!--
        Root preference overlay for the app. The default androidx
        @style/PreferenceThemeOverlay sets switchPreferenceCompatStyle, which
        SHADOWS the activity-theme-level override defined in
        DayNightPreferenceTheme. PreferenceFragmentCompat reads
        ?attr/preferenceTheme and uses that overlay's attributes when
        inflating preferences, so we must override the attribute here too,
        otherwise our custom widgetLayout never reaches the SwitchCompat.
    -->
    <style name="PreferenceThemeOverlay.ForPDA" parent="PreferenceThemeOverlay">
        <item name="switchPreferenceCompatStyle">@style/SwitchPreferenceCompatStyle</item>
    </style>

