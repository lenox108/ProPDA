    <style name="DayNightAppTheme.Gruvbox.Dialog" parent="Base.ForPDA.Dialog">
        <item name="android:colorBackground">@color/gruvbox_card_background</item>
        <item name="colorAccent">@color/gruvbox_colorAccent</item>
        <item name="colorPrimary">@color/gruvbox_link_color</item>
        <item name="colorOnSurface">@color/gruvbox_default_text_color</item>
        <item name="colorOnPrimary">@color/gruvbox_link_color_contrast</item>
        <item name="colorPrimaryContainer">@color/gruvbox_background_for_cards</item>
        <item name="colorOnPrimaryContainer">@color/gruvbox_default_text_color</item>
        <item name="colorOutline">@color/gruvbox_divider_line</item>
        <item name="colorOutlineVariant">@color/gruvbox_divider_line</item>
        <item name="android:textColorPrimary">@color/gruvbox_default_text_color</item>
        <item name="android:textColorSecondary">@color/gruvbox_second_text_color</item>
        <item name="android:textColorHint">@color/gruvbox_second_text_color</item>
        <item name="colorSurface">@color/gruvbox_card_background</item>
        <item name="colorOnSurfaceVariant">@color/gruvbox_second_text_color</item>
        <item name="textInputStyle">@style/DialogTextInputStyle</item>
    </style>

    <style name="DayNightAppTheme.Gruvbox.BottomSheetDialog" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:colorBackground">@color/gruvbox_colorPrimary</item>
        <item name="colorSurface">@color/gruvbox_colorPrimary</item>
        <item name="colorOnSurface">@color/gruvbox_default_text_color</item>
        <item name="colorOnSurfaceVariant">@color/gruvbox_second_text_color</item>
        <item name="textInputStyle">@style/DialogTextInputStyle</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.ForPDA.BottomSheet</item>
    </style>

    <style name="DayNightAppTheme.Gruvbox.NoActionBarBase" parent="DayNightAppTheme.Gruvbox">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/gruvbox_navigation_bar_color</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <style name="DayNightAppTheme.Gruvbox.NoActionBar" parent="DayNightAppTheme.Gruvbox.NoActionBarBase" />

    <style name="DayNightPreferenceTheme.Gruvbox" parent="DayNightAppTheme.Gruvbox">
        <item name="switchPreferenceCompatStyle">@style/SwitchPreferenceCompatStyle</item>
    </style>

    <style name="DayNightAppTheme.Gruvbox.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:singleLine">true</item>
        <item name="colorSurface">@color/gruvbox_card_background</item>
        <item name="colorControlNormal">@color/gruvbox_icon_toolbar</item>
        <item name="colorOnSurface">@color/gruvbox_icon_toolbar</item>
        <item name="actionMenuTextColor">@color/gruvbox_icon_toolbar</item>
        <item name="android:textColorPrimary">@color/gruvbox_icon_toolbar</item>
        <item name="android:textColorSecondary">@color/gruvbox_icon_toolbar</item>
        <item name="colorPrimary">@color/gruvbox_link_color</item>
        <item name="colorPrimaryContainer">@color/gruvbox_background_for_cards</item>
        <item name="colorOnPrimaryContainer">@color/gruvbox_default_text_color</item>
        <item name="popup_overlay">@style/DayNightAppTheme.Gruvbox.PopupOverlay</item>
    </style>

    <style name="DayNightAppTheme.Gruvbox.PopupOverlay" parent="DayNightAppTheme.PopupOverlay">
        <item name="colorSurface">@color/gruvbox_card_background</item>
        <item name="colorOnSurface">@color/gruvbox_default_text_color</item>
        <item name="colorOnSurfaceVariant">@color/gruvbox_second_text_color</item>
        <item name="android:textColorPrimary">@color/gruvbox_default_text_color</item>
        <item name="android:textColorSecondary">@color/gruvbox_second_text_color</item>
    </style>
</resources>
