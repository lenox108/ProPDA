    </style>

    <style name="DayNightAppTheme.RosePine.NoActionBarBase" parent="DayNightAppTheme.RosePine">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/rose_pine_navigation_bar_color</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <style name="DayNightAppTheme.RosePine.NoActionBar" parent="DayNightAppTheme.RosePine.NoActionBarBase" />

    <style name="DayNightPreferenceTheme.RosePine" parent="DayNightAppTheme.RosePine">
        <item name="switchPreferenceCompatStyle">@style/SwitchPreferenceCompatStyle</item>
    </style>

    <style name="DayNightAppTheme.RosePine.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:singleLine">true</item>
        <item name="colorSurface">@color/rose_pine_card_background</item>
        <item name="colorControlNormal">@color/rose_pine_icon_toolbar</item>
