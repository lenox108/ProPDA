<?xml version="1.0" encoding="utf-8"?>
<!--
    Accent-оверлеи «смены цвета» (курируемые палитры). Накладываются per-activity
    через AccentApplier.applyStyle ПОВЕРХ базовой темы (light/dark/amoled), только
    при палитре SYSTEM и когда Material You неактивен. Цвета — @color/accent_* из
    colors_accents.xml (day) / values-night (night), сгенерированы AccentPaletteGenerator.
    Перекрываем только акцентные M3-роли — поверхности/фон остаются нейтральными.
-->
<resources>
    <style name="ThemeOverlay.ForPDA.Accent.Blue" parent="">
        <item name="colorPrimary">@color/accent_blue_primary</item>
        <item name="colorOnPrimary">@color/accent_blue_on_primary</item>
        <item name="colorPrimaryContainer">@color/accent_blue_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/accent_blue_on_primary_container</item>
        <item name="colorPrimaryInverse">@color/accent_blue_inverse_primary</item>
        <item name="colorSecondary">@color/accent_blue_secondary</item>
        <item name="colorOnSecondary">@color/accent_blue_on_secondary</item>
        <item name="colorSecondaryContainer">@color/accent_blue_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/accent_blue_on_secondary_container</item>
        <item name="colorTertiary">@color/accent_blue_tertiary</item>
        <item name="colorOnTertiary">@color/accent_blue_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/accent_blue_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/accent_blue_on_tertiary_container</item>
        <item name="colorAccent">@color/accent_blue_primary</item>
        <item name="android:colorAccent">@color/accent_blue_primary</item>
    </style>
