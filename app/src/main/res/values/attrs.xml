    <attr name="is_use_light_status_bar" format="boolean" />

    <attr name="ProfileToolbarTextStyle" extension="reference" />
    <attr name="colorSwitchTrackNormal" format="color" />
    <attr name="colorSwitchThumbNormal" format="color" />

    <declare-styleable name="AspectRatio">
