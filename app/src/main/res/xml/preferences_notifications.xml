<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:title="@string/pref_title_notifications">
    <PreferenceCategory
        android:layout="@layout/preference_category_custom_top"
        android:title="@string/pref_title_main">
        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:key="notifications.main.enabled"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_notify"
            app:iconSpaceReserved="false" />

        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.main.enabled"
            android:key="notifications.main.avatars_enabled"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_enable_avatars"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!--
      Загрузки намеренно вне главного тумблера: это не push, а прогресс действия, которое
      пользователь запустил сам. Так же считает и код — wantsPushNotifications() учитывает
      только темы/QMS/упоминания, а DownloadWorker смотрит исключительно на свой флаг.
    -->
    <PreferenceCategory
        android:layout="@layout/preference_category_custom"
        android:title="@string/downloads">
        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:key="notifications.downloads.enabled"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_download_notifications"
            android:title="@string/pref_title_download_notifications"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory
        android:layout="@layout/preference_category_custom"
        android:title="@string/pref_title_favorites">
        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.main.enabled"
            android:key="notifications.fav.enabled"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_notify"
            app:iconSpaceReserved="false" />

        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="false"
            android:dependency="notifications.fav.enabled"
            android:key="notifications.fav.only_important"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_only_important"
            app:iconSpaceReserved="false" />

        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.fav.enabled"
            android:key="notifications.fav.live_tab"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_favorites_live_tab"
            android:title="@string/pref_title_favorites_live_tab"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:layout="@layout/preference_category_custom"
        android:title="@string/pref_title_mentions">
        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.main.enabled"
            android:key="notifications.mentions.enabled"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_notify"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:layout="@layout/preference_category_custom"
        android:title="@string/pref_title_pm_qms">
        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.main.enabled"
            android:key="notifications.qms.enabled"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_notify"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:layout="@layout/preference_category_custom"
        android:title="@string/pref_title_hat_watch">

        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.main.enabled"
            android:key="notifications.hat.enabled"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_hat_watch"
            android:title="@string/pref_title_notify"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:layout="@layout/preference_category_custom"
        android:title="@string/pref_title_bg_check">

        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="true"
            android:dependency="notifications.main.enabled"
            android:key="notifications.bg.enabled"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_bg_check"
            android:title="@string/pref_title_bg_check"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:defaultValue="30"
            android:dependency="notifications.bg.enabled"
            android:dialogTitle="@string/pref_title_bg_check_interval"
            android:entries="@array/entries_notify_bg_interval"
            android:entryValues="@array/entry_values_notify_bg_interval"
            android:key="notifications.bg.interval_min"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_bg_check_interval"
            app:iconSpaceReserved="false" />

        <forpdateam.ru.forpda.ui.views.SwitchPreference
            android:defaultValue="false"
            android:dependency="notifications.bg.enabled"
            android:key="notifications.bg.persistent_ws"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_persistent_ws"
            android:title="@string/pref_title_persistent_ws"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.bg.battery_optimization"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_battery_optimization"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.bg.oem_autostart"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_oem_autostart"
            android:title="@string/pref_title_oem_autostart"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.bg.diagnostics"
            android:layout="@layout/preference_custom"
            android:persistent="false"
            android:summary="@string/pref_summary_bg_check_diagnostics"
            android:title="@string/pref_title_bg_check_diagnostics"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory
        android:key="notifications.system.category"
        android:layout="@layout/preference_category_custom"
        android:title="@string/pref_title_android_notification_settings">
        <Preference
            android:key="notifications.system.app"
            android:layout="@layout/preference_custom"
            android:summary="@string/pref_summary_android_notification_settings"
            android:title="@string/pref_title_open_android_notification_settings"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.system.channel.qms"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_channel_qms"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.system.channel.mentions"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_channel_mentions"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.system.channel.favorites"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_channel_favorites"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notifications.system.channel.downloads"
            android:layout="@layout/preference_custom"
            android:title="@string/pref_title_channel_downloads"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

</PreferenceScreen>